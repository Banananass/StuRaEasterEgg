# ------------------------------------------------------------------
# .htaccess for StuRaEasterEgg
#
# Goal: Only "index.php" may be requested directly by the browser.
# All other project/source files (TypeScript sources, source maps,
# config/build files, dotfiles, VCS metadata, etc.) are blocked from
# direct access. Static assets that the page itself needs to load
# (JS, CSS, images referenced by index.php) remain accessible, since
# the browser must be able to fetch them as separate requests.
# ------------------------------------------------------------------

DirectoryIndex index.php
Options -Indexes -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Let requests for index.php itself through untouched.
    RewriteCond %{REQUEST_URI} ^/(.*/)?index\.php$ [NC]
    RewriteRule ^ - [L]

    # Let requests for the static assets the page needs through untouched.
    RewriteCond %{REQUEST_URI} \.(js|css|png|jpe?g|gif|svg|webp|ico|woff2?|ttf)$ [NC]
    RewriteRule ^ - [L]

    # Everything else that maps to a real file on disk gets blocked (403),
    # e.g. .ts/.map/.json/.md/.lock/.yml files, dotfiles, other .php files, ...
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [F,L]
</IfModule>

# Fallback for servers without mod_rewrite: deny dotfiles and known source/meta extensions.
<IfModule !mod_rewrite.c>
    <FilesMatch "^\.|\.(ts|map|md|json|lock|yml|yaml|log)$">
        Require all denied
    </FilesMatch>

    <Files "*.php">
        Require all denied
    </Files>
    <Files "index.php">
        Require all granted
    </Files>
</IfModule>


